<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>

    <PackageId>Mailchimp.Umbraco</PackageId>
    <Version>0.1.0</Version>

    <Authors>Jebastin</Authors>
    <Description>Mailchimp workflow integration for Umbraco Forms</Description>

    <PackageTags>umbraco mailchimp forms workflow</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>

    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Umbraco.Forms.Core.Providers" Version="[14.0.0,15.0.0)" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Umbraco.Forms.Core.Providers" Version="[17.0.0,18.0.0)" />
  </ItemGroup>

</Project>
